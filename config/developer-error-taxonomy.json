{
  "version": "1.0.0",
  "scope": "Classes de erros de desenvolvimento que o Pingu deve detectar, corrigir automaticamente quando houver transformacao segura, ou sinalizar quando depender de contexto externo.",
  "families": [
    {
      "id": "syntax_structure",
      "description": "Aspas, delimitadores, virgulas, blocos e fences quebrados.",
      "mappedIssueKinds": ["syntax_missing_quote", "syntax_missing_delimiter", "syntax_missing_comma", "syntax_extra_delimiter", "syntax_malformed_keyword"],
      "safeAutoFix": true,
      "languages": ["javascript", "python", "elixir", "go", "rust", "ruby", "lua", "vim", "c", "terraform", "yaml", "markdown", "mermaid", "dockerfile", "shell", "toml"]
    },
    {
      "id": "workspace_hygiene",
      "description": "Tabs, espacos finais, linhas duplicadas, TODO/FIXME sem contrato e saidas de debug.",
      "mappedIssueKinds": ["tabs", "trailing_whitespace", "duplicate_line", "todo_fixme", "debug_output"],
      "safeAutoFix": true,
      "languages": ["javascript", "python", "elixir", "go", "rust", "ruby", "lua", "vim", "c", "terraform", "yaml", "markdown", "mermaid", "dockerfile", "shell", "toml"]
    },
    {
      "id": "nullability_and_equality",
      "description": "Comparacoes frouxas ou idiomaticamente incorretas contra valores nulos.",
      "mappedIssueKinds": ["loose_equality", "none_comparison", "nil_comparison"],
      "safeAutoFix": true,
      "languages": ["javascript", "python", "ruby"]
    },
    {
      "id": "typo_and_naming",
      "description": "Erros de digitacao em palavras-chave e builtins. Pingu sugere a correcao mais provavel, mas nunca reescreve automaticamente.",
