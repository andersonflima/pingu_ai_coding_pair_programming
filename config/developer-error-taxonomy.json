      "safeAutoFix": false,
      "languages": ["javascript", "python", "ruby", "go", "rust"]
    },
    {
      "id": "imports_and_dependencies",
      "description": "Imports inexistentes, exports incorretos, includes/use ausentes, imports nao utilizados e dependencias exigidas por snippets.",
      "mappedIssueKinds": ["undefined_variable", "missing_dependency", "unused_import"],
      "safeAutoFix": true,
      "languages": ["javascript", "python", "elixir", "go", "rust", "c"]
    },
    {
      "id": "error_handling",
      "description": "Captura ampla demais, erros ignorados e fluxos que escondem falhas.",
      "mappedIssueKinds": ["bare_except", "swallowed_error"],
      "safeAutoFix": true,
      "languages": ["python"]
    },
    {
      "id": "public_contract",
      "description": "Funcoes, classes, specs, moduledocs, variaveis relevantes e contratos sem documentacao suficiente.",
      "mappedIssueKinds": ["function_doc", "class_doc", "function_spec", "moduledoc", "variable_doc", "function_comment", "flow_comment"],
      "safeAutoFix": true,
      "languages": ["javascript", "python", "elixir", "go", "rust", "ruby", "lua", "vim", "c"]
    },
    {
      "id": "architecture_and_tests",
      "description": "Contexto arquitetural ausente, scaffolds solicitados, cobertura de testes e contratos de arquivos estruturados.",
      "mappedIssueKinds": ["comment_task", "context_file", "context_contract", "unit_test", "unit_test_signature"],
      "safeAutoFix": true,
      "languages": ["javascript", "python", "elixir", "go", "rust", "ruby", "lua", "vim", "c", "terraform", "yaml", "markdown", "mermaid", "dockerfile", "shell", "toml"]
    },
    {
      "id": "control_flow_and_complexity",
      "description": "Condicionais profundas, reatribuicao imperativa, atribuicao acidental em condicao, codigo inalcancavel e fluxo dificil de testar.",
