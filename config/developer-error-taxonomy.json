      "safeAutoFix": false,
      "languages": ["javascript", "python", "elixir", "go", "rust", "ruby", "lua", "vim", "c"]
    },
    {
      "id": "runtime_commands",
      "description": "Acoes de terminal, testes, build, lint, formatacao e scripts locais com politica de risco.",
