{
  "name": "pingu-dev-agent",
  "description": "Pingu - Dev Agent: agente de pair programming em tempo real para Vim, Neovim e LazyVim.",
  "version": "0.1.39",
  "license": "MIT",
  "keywords": [
    "pingu",
    "dev-agent",
    "pair-programming",
    "agent",
    "vim",
    "neovim",
    "lazyvim"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andersonflima/pingu_ai_codding_pair_programming.git"
  },
  "homepage": "https://github.com/andersonflima/pingu_ai_codding_pair_programming#readme",
  "bugs": {
    "url": "https://github.com/andersonflima/pingu_ai_codding_pair_programming/issues"
  },
  "bin": {
    "pingu": "realtime_dev_agent.js"
  },
  "scripts": {
    "check": "npm run lint && npm run check:vim-runtime && npm test",
    "check:vim-runtime": "node scripts/sync-vim-runtime.js --check",
    "ci:release": "npm run check && npm run pack:check && npm run release:check",
    "pack:check": "npm pack --dry-run --json",
    "profile": "node scripts/profile-analyzer.js",
    "release:check": "node scripts/check-release-version.js",
    "release:prepare": "node scripts/check-release-version.js --prepare",
    "smoke:vim": "node scripts/smoke-vim-runtime.js",
    "sync:vim-runtime": "node scripts/sync-vim-runtime.js --write",
    "lint": "node scripts/check-syntax.js",
    "test": "node --test test/*.js test/**/*.js"
  },
  "files": [
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "assets/",
    "autoload/",
    "config/",
    "docs/",
    "lib/",
    "plugin/",
    "realtime_dev_agent.js",
    "scripts/",
    "vim/"
  ]
}
