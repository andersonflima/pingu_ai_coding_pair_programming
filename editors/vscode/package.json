{
  "name": "pingu-vscode",
  "displayName": "Pingu",
  "description": "Diagnosticos de pair-programming e quick fixes do Pingu, via o servidor LSP (pingu lsp).",
  "version": "0.1.0",
  "publisher": "andersonflima",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/andersonflima/pingu_ai_coding_pair_programming.git",
    "directory": "editors/vscode"
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:ruby",
    "onLanguage:elixir",
    "onLanguage:lua",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:shellscript",
    "onLanguage:php",
    "onLanguage:java",
    "onLanguage:csharp"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Pingu",
      "properties": {
        "pingu.serverCommand": {
          "type": "string",
          "default": "pingu",
          "description": "Comando que inicia o servidor LSP do Pingu. Use um caminho absoluto se 'pingu' nao estiver no PATH."
        },
        "pingu.serverArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "lsp"
          ],
          "description": "Argumentos passados ao comando do servidor."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.24.0"
  }
}
